{
  "name": "buddy",
  "version": "1.0.0",
  "description": "Buddy — AI Desktop Companion",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "@azure/msal-node": "^2.6.0",
    "@google/generative-ai": "^0.2.1",
    "dotenv": "^16.4.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.buddy.desktop",
    "productName": "Buddy",
    "copyright": "Copyright © 2026",
    "publish": [
      {
        "provider": "github",
        "owner": "authenticTyagi",
        "repo": "buddy"
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Buddy"
    },
    "files": [
      "**/*",
      "!buddy.log",
      "!.env",
      "!.github",
      "!*.md",
      "!node_modules/.cache"
    ],
    "extraResources": [
      { "from": "config.json", "to": "config.json" }
    ]
  }
}